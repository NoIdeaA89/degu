{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["jest", "node"],
    "baseUrl": ".",
    "paths": {
      "@generated/*": ["src/generated/*"]
    }
  },
  "include": [
    "src/**/*",
    "database/**/*",
    "tests/**/*"
, "src/lib", "prisma", "prisma.config.js"  ]
}