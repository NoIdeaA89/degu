generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id               Int           @id @default(autoincrement())
  nombre           String
  apellido         String
  rut              String        @unique
  correo           String        @unique
  password         String
  rol              RolUsuario
  asistencias      Asistencia[]
  inscripciones    Inscripcion[]
  talleresDictados Taller[]      @relation("ProfesorTaller")
}

model Taller {
  id            Int           @id @default(autoincrement())
  nombre        String
  descripcion   String
  horario       String
  semestre      String
  estado        Boolean       @default(true)
  profesorId    Int
  bloques       BloqueHorario[] @default([A])
  dia           Int           @default(1)
  lugar         String        @default("Galpón Cultural")
  inscripciones Inscripcion[]
  sesiones      Sesion[]
  profesor      Usuario       @relation("ProfesorTaller", fields: [profesorId], references: [id])
}

model Inscripcion {
  id            Int      @id @default(autoincrement())
  fechaRegistro DateTime @default(now())
  estudianteId  Int
  tallerId      Int
  estudiante    Usuario  @relation(fields: [estudianteId], references: [id])
  taller        Taller   @relation(fields: [tallerId], references: [id])

  @@unique([estudianteId, tallerId])
}

model Sesion {
  id          Int          @id @default(autoincrement())
  tallerId    Int
  fecha       DateTime     @default(now()) @db.Date
  qrToken     String       @unique
  validoHasta DateTime
  bloque      Int
  asistencias Asistencia[]
  taller      Taller       @relation(fields: [tallerId], references: [id])
}

model Asistencia {
  id               Int      @id @default(autoincrement())
  sesionId         Int
  estudianteId     Int
  fechaHora        DateTime @default(now())
  estado           String   @default("Ausente")
  notaSatisfaccion Int?
  comentario       String?
  estudiante       Usuario  @relation(fields: [estudianteId], references: [id])
  sesion           Sesion   @relation(fields: [sesionId], references: [id])

  @@unique([sesionId, estudianteId])
}

enum RolUsuario {
  Administrador
  Profesor
  Ayudante
  Estudiante
}

enum BloqueHorario {
  A
  B
  C
  C2
  D
  E
  F
  G
}
