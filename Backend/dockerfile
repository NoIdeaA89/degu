FROM node:24-slim

# Dependencias físicas del motor
RUN apt-get update -y && apt-get install -y openssl ca-certificates

WORKDIR /app

COPY package*.json ./

# Instalamos tsx globalmente para que Prisma pueda leer el config en TypeScript
RUN npm install -g tsx
RUN npm install

COPY prisma ./prisma/
# Copiamos explícitamente el archivo de configuración TypeScript
COPY prisma.config.ts ./  

RUN npx prisma generate

COPY . .
RUN npm run build

EXPOSE 3000

# Usamos DIRECT_URL (puerto 5432) temporalmente para la migración,
# y dejamos que npm start corra con DATABASE_URL (puerto 6543)
CMD ["sh", "-c", "DATABASE_URL=$DIRECT_URL npx prisma migrate deploy && npm start"]