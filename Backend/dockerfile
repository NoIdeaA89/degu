FROM node:24-slim

# Instalar dependencias físicas requeridas por el motor de Prisma
RUN apt-get update -y && apt-get install -y openssl ca-certificates

WORKDIR /app

# Copiar archivos de dependencias
COPY package*.json ./

# Instalar todas las dependencias (incluyendo TypeScript y las de desarrollo para poder compilar)
RUN npm install

# Copiar el esquema y generar el cliente de Prisma (con sus tipos de TypeScript)
COPY prisma ./prisma/
RUN npx prisma generate

# Copiar todo el código fuente (aquí se incluye tu tsconfig.json y archivos .ts)
COPY . .

# ¡CRUCIAL! Compilar TypeScript a JavaScript antes de empaquetar la imagen
RUN npm run build

EXPOSE 3000

# Ejecutar las migraciones en Supabase y arrancar el código ya compilado
CMD ["sh", "-c", "npx prisma migrate deploy && npm start"]