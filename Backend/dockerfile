# ── Builder stage ────────────────────────────────────────────────────────────
FROM node:24-alpine AS builder

WORKDIR /app

# 1. Install all dependencies (devDependencies needed for TypeScript compilation)
COPY package*.json ./
RUN npm install

# 2. Copy source code and config
COPY . .

# 3. Generate Prisma client (must happen before tsc so generated types are available)
RUN npx prisma generate

# 4. Compile TypeScript → dist/
RUN npm run build

# ── Runtime stage ─────────────────────────────────────────────────────────────
FROM node:24-alpine AS runtime

WORKDIR /app

# 5. Copy only the artifacts needed at runtime from the builder
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/prisma ./prisma
COPY --from=builder /app/package.json ./package.json
COPY --from=builder /app/package-lock.json ./package-lock.json

# 6. Expose port (Railway injects its own PORT at runtime)
EXPOSE 3000

# 7. Run migrations then start the compiled app
CMD ["sh", "-c", "npx prisma migrate deploy && node dist/index.js"]