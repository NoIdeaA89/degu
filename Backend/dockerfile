FROM node:24-alpine AS dev

WORKDIR /app

# Copia package.json y package-lock.json
COPY package*.json ./

# Instala todas las deps (incluyendo dev)
RUN npm install

COPY prisma ./prisma/

RUN npx prisma generate

COPY . .

EXPOSE 3000

# CMD para desarrollo
CMD ["sh", "-c", "npx prisma migrate deploy && npm start"]
