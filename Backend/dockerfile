# 1. Cambiamos a slim para garantizar compatibilidad con el motor de Prisma
FROM node:22

# 2. Instalamos OpenSSL y certificados, requeridos por Prisma para conectarse a Supabase
RUN apt-get update -y && apt-get install -y openssl ca-certificates

WORKDIR /app

# 3. Copiamos los archivos de dependencias
COPY package*.json ./

# 4. Instalamos las dependencias
RUN npm install

# 5. Copiamos el esquema y generamos el cliente de Prisma para Linux Debian
COPY prisma ./prisma/
RUN npx prisma generate

# 6. Copiamos el resto del código fuente del backend
COPY . .

# 7. (Opcional) Si tu código usa TypeScript, descomenta la siguiente línea para compilar
# RUN npm run build

# 8. Railway ignora el EXPOSE, pero es buena práctica mantenerlo para documentación
EXPOSE 3000

# 9. Ejecuta las migraciones hacia Supabase y luego arranca Express
CMD ["sh", "-c", "npx prisma migrate deploy && npm start"]
