# =================================================================
# PLANTILLA DE VARIABLES DE ENTORNO
# =================================================================
# INSTRUCCIONES PARA EL EQUIPO: 
# 1. Copia este archivo y renómbralo como '.env'
# 2. Los valores por defecto funcionan para el entorno de Docker local.
# 3. NUNCA hagas commit de tu archivo '.env' personal.
# =================================================================

# -----------------------------------------------------------------
# Conexión para Prisma y scripts de Node
# -----------------------------------------------------------------

# Opción A: Si ejecutas Prisma/Node directamente desde tu PC (Localhost):
DATABASE_URL="postgresql://user:password@localhost:5432/app_db?schema=public"

# Opción B: Si el backend corre dentro de Docker (Red interna):
# (Descomenta esta línea y comenta la de arriba si es tu caso)
# DATABASE_URL="postgresql://user:password@database:5432/app_db?schema=public"

# -----------------------------------------------------------------
# Configuración del contenedor de Base de Datos (PostgreSQL)
# -----------------------------------------------------------------
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=app_db

# -----------------------------------------------------------------
# Configuración del Servidor Backend
# -----------------------------------------------------------------
PORT=3000

# -----------------------------------------------------------------
# Seguridad e Identificación del Entorno
# -----------------------------------------------------------------
JWT_SECRET=escribe_un_secreto_aleatorio_para_local_123
NODE_ENV=development